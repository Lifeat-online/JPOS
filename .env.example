# PayFast — get these from your PayFast dashboard.
# NEVER commit real values. .env is git-ignored; use .env.docker.local in
# Docker and a secrets manager / Hetzner/Coolify variables in production.
PAYFAST_MERCHANT_ID="REPLACE_WITH_YOUR_MERCHANT_ID"
PAYFAST_MERCHANT_KEY="REPLACE_WITH_YOUR_MERCHANT_KEY"
PAYFAST_PASSPHRASE="REPLACE_WITH_YOUR_PASSPHRASE"
PAYFAST_SANDBOX="true"

# MariaDB / Postgres
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD=""
DB_DATABASE="jimmy_pos"
DB_CONNECTION_LIMIT="10"

# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Min 32 chars; rotate when staff with access leaves.
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
JWT_EXPIRES_IN="8h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Auth throttling: production defaults to 5 attempts per 15 min.
# Set AUTH_RATE_LIMIT_DISABLED=true only for local dev.
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX=""
AUTH_RATE_LIMIT_DISABLED="false"

# CORS — comma-separated list of allowed origins. Empty = same-origin only.
# Examples:
#   CORS_ORIGINS="https://masepos.co.za,https://app.masepos.co.za"
#   CORS_ORIGINS="https://masepos.co.za,capacitor://localhost,ionic://localhost"
CORS_ORIGINS=""

# Public app/API URL used for payment callback URLs when the request host is
# not the public production host.
PUBLIC_APP_URL=""

# Optional client bundle overrides for mobile shells, WebViews, separate
# frontends, or hybrid on-prem/cloud deployments. Leave empty for same-origin
# PWA use.
#
# VITE_DEPLOYMENT_MODE:
#   cloud   = hosted backend only.
#   on_prem = local store server only.
#   hybrid  = on-prem primary with safe read fallback to cloud, or the
#             operator-selected target from Settings > Connection.
VITE_DEPLOYMENT_MODE="cloud"
VITE_API_BASE_URL=""
VITE_CLOUD_API_BASE_URL=""
VITE_ON_PREM_API_BASE_URL=""
VITE_SOCKET_URL=""

# Optional multi-instance realtime fan-out. Leave disabled for a single Node
# process. Set JPOS_REALTIME_FANOUT=database when multiple app instances share
# the same database and need Socket.IO room events fanned out across instances.
JPOS_REALTIME_FANOUT=""
JPOS_REALTIME_POLL_MS="1000"
JPOS_REALTIME_EVENT_TTL_MINUTES="10"
JPOS_REALTIME_INSTANCE_ID=""

# Trust-proxy hop count. Set to 1 when behind Hetzner/Coolify/nginx, 0 in dev.
TRUST_PROXY_HOPS="0"

# Dev-bootstrap backdoor. When true, the hardcoded dev email gets the
# dev role + tenant1 assigned automatically (legacy behaviour). Leave
# FALSE in production. Set to true only in local dev / staging.
ENABLE_DEV_BOOTSTRAP="false"
# Same flag for the client bundle:
# VITE_ENABLE_DEV_BOOTSTRAP="false"

# White-label licensing
# Hosted SaaS/Hetzner: set JPOS_HOSTED=true to expose admin licence endpoints.
# Self-hosted Docker: bake LICENCE_SECRET into the image and customers set LICENCE_KEY only.
JPOS_HOSTED="false"
JPOS_REQUIRE_LICENCE="false"
JPOS_LICENCE_SERVER="https://masepos.co.za"
LICENCE_KEY=""
LICENCE_SECRET=""
ADMIN_API_KEY=""

# Global API rate limit (per IP, per minute). Set to 0 to disable (dev only).
API_RATE_LIMIT_PER_MIN="300"

# AI Manager Copilot providers. Secrets stay server-side.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"
ANYTHINGLLM_BASE_URL="http://localhost:3001"
ANYTHINGLLM_API_KEY=""
ANYTHINGLLM_WORKSPACE_SLUG=""
GOOGLE_AI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"
GOOGLE_VERTEX_API_KEY=""
GOOGLE_VERTEX_ACCESS_TOKEN=""
GOOGLE_VERTEX_SERVICE_ACCOUNT_JSON=""
GOOGLE_VERTEX_PROJECT_ID=""
GOOGLE_VERTEX_LOCATION="us-central1"
GOOGLE_VERTEX_MODEL="gemini-2.5-flash"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-5-mini"
