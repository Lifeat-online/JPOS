# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PayFast Configuration
# Get these from your PayFast account dashboard
# Default sandbox values from PayFast docs for testing
PAYFAST_MERCHANT_ID="REPLACE_WITH_YOUR_MERCHANT_ID"
PAYFAST_MERCHANT_KEY="REPLACE_WITH_YOUR_MERCHANT_KEY"
PAYFAST_PASSPHRASE="REPLACE_WITH_YOUR_PASSPHRASE"
PAYFAST_SANDBOX="true"

# MariaDB Configuration
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD=""
DB_DATABASE="jimmy_pos"
DB_CONNECTION_LIMIT="10"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="8h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# White-label licensing
# Hosted SaaS/Railway: set JPOS_HOSTED=true to expose admin licence endpoints.
# Self-hosted Docker: bake LICENCE_SECRET into the image and customers set LICENCE_KEY only.
JPOS_HOSTED="false"
JPOS_REQUIRE_LICENCE="false"
JPOS_LICENCE_SERVER="https://jpos-production.up.railway.app"
LICENCE_KEY=""
ADMIN_API_KEY=""

# AI Manager Copilot providers. Secrets stay server-side.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"
ANYTHINGLLM_BASE_URL="http://localhost:3001"
ANYTHINGLLM_API_KEY=""
ANYTHINGLLM_WORKSPACE_SLUG=""
GOOGLE_AI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-5-mini"
