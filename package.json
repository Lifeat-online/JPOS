{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:emulator": "concurrently --kill-others --names \"EMU,APP\" --prefix-colors \"yellow,cyan\" \"npx firebase-tools emulators:start --only auth,firestore\" \"cross-env VITE_USE_EMULATOR=true tsx server.ts\"",
    "build": "vite build",
