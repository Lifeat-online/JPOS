{
  "name": "mase-pos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.12.0 <23",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:init": "tsx server/init-db.ts",
    "test:unit": "cross-env NODE_ENV=test vitest run",
    "test:api": "cross-env NODE_ENV=test vitest run tests/backend/auth-middleware.test.ts tests/backend/auth-handler.test.ts tests/backend/api.test.ts tests/backend/licence.test.ts tests/backend/mariadb-adapter.test.ts tests/backend/mariadb-crud.test.ts tests/backend/db-tables.test.ts",
    "test:e2e": "cross-env NODE_ENV=test playwright test",
    "test": "npm run test:unit && npm run test:api",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "smoke:stocktake": "tsx scripts/stocktake-smoke.ts",
    "ops:verify-endpoint": "tsx scripts/verify-production-endpoint.ts",
    "ops:verify-schema": "tsx scripts/verify-production-schema.ts",
    "seed:test-tenant": "tsx scripts/seed-test-tenant.ts",
    "security:scan": "npm audit --omit=dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "3.6.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.12",
    "express-rate-limit": "^7.0.0",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.27.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tsx": "^4.21.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11",
    "@types/socket.io": "^3.0.1",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^2.0.14",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "jsdom": "^22.1.0",
    "supertest": "^6.3.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
