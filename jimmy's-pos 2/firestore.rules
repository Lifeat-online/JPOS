rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Hardcoded admin email for bootstapping security
      return isSignedIn() && request.auth.token.email == 'jameskoen78@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny: Zero-Trust by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------
    // ENTITY VALIDATION
    // ------------------------------------------------------------

    function isValidProduct(data) {
      return (data.name is string && data.name.size() > 0 && data.name.size() < 200) &&
             (data.price is number && data.price >= 0) &&
             (data.category is string) &&
             (data.stock is number) &&
             (!('section' in data) || data.section is string) &&
             (!('subCategory' in data) || data.subCategory is string);
    }

    function isValidSale(data) {
      return data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.paymentMethod in ['cash', 'payfast', 'card'] &&
             data.status in ['pending', 'completed', 'failed'] &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function isValidCustomer(data) {
      return (data.name is string && data.name.size() > 0) &&
             (data.email is string && data.email.size() > 0);
    }

    function isValidStaff(data) {
      return (data.name is string && data.name.size() > 0) &&
             (data.email is string && data.email.size() > 0) &&
             (data.role in ['admin', 'cashier', 'manager']);
    }

    // ------------------------------------------------------------
    // MATCH BLOCKS
    // ------------------------------------------------------------

    // Products: Publicly readable for the POS terminal, Admin only for stock/edits
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && incoming().keys().hasAll(['name', 'price', 'category', 'stock']) && isValidProduct(incoming());
      allow update: if (isAdmin() && isValidProduct(incoming())) || 
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['stock']));
      allow delete: if isAdmin();
    }

    // Sales: Anyone can record a sale (Auth create), but only Admin can see all history. Cashiers see their own.
    match /sales/{saleId} {
      allow create: if isSignedIn() && incoming().keys().hasAll(['items', 'total', 'paymentMethod', 'status', 'createdAt']) && isValidSale(incoming());
      allow get, list: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Customers: Admin only
    match /customers/{customerId} {
      allow create: if isAdmin() && incoming().keys().hasAll(['name', 'email']) && isValidCustomer(incoming());
      allow read, update, delete: if isAdmin();
    }

    // Staff: Readable by all signed in users so they can determine their role. Write by Admin, but users can update their wallet.
    match /staff/{staffId} {
      allow create: if isAdmin() && incoming().keys().hasAll(['name', 'email', 'role']) && isValidStaff(incoming());
      allow read: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /payoutRequests/{requestId} {
      allow read, write: if isSignedIn();
    }

    // Settings: Readable by all signed in users. Formatted as settings/app.
    match /settings/{documentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Config: Legacy fallback
    match /config/{configId} {
      allow read, write: if isAdmin();
    }
    // Vendors
    match /vendors/{vendorId} {
      allow read, write: if isSignedIn();
    }

    // PurchaseOrders
    match /purchaseOrders/{poId} {
      allow read, write: if isSignedIn();
    }

    // CashSessions
    match /cashSessions/{sessionId} {
      allow read, write: if isSignedIn();
    }

    // CashTransactions
    match /cashTransactions/{txId} {
      allow read, write: if isSignedIn();
    }
  }
}
